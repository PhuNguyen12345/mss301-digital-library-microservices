# Copy this file to .env. Never commit the resulting .env file.

# Local Keycloak infrastructure
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-a-long-random-admin-password
KEYCLOAK_DB_USERNAME=keycloak
KEYCLOAK_DB_PASSWORD=replace-with-a-long-random-keycloak-database-password

# The values below must describe the same Keycloak deployment and realm.
# Do not add a trailing slash to KEYCLOAK_BASE_URL.
# The aggregate docker-compose.yml assumes this is a public/hosted Keycloak.
KEYCLOAK_BASE_URL=https://keycloak.example.com
KEYCLOAK_REALM=digilib-realm
KEYCLOAK_ISSUER_URI=https://keycloak.example.com/realms/digilib-realm
KEYCLOAK_CLIENT_ID=digilib-auth
KEYCLOAK_CLIENT_SECRET=replace-with-the-newly-regenerated-client-secret
INTERNAL_API_KEY=replace-with-a-separate-long-random-service-key

# Monitoring infrastructure.
LOKI_GCS_BUCKET=replace-with-the-loki-gcs-bucket-name
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-long-random-grafana-password
GRAFANA_ROOT_URL=http://localhost:3000

# Comma-separated browser origins allowed to call API Gateway.
GATEWAY_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# API Gateway resilience guardrails. Duration values use Spring's format.
GATEWAY_CONNECT_TIMEOUT_MS=1000
GATEWAY_RESPONSE_TIMEOUT=5s
GATEWAY_AUTH_RESPONSE_TIMEOUT_MS=15000
GATEWAY_FILE_RESPONSE_TIMEOUT_MS=30000
GATEWAY_CIRCUIT_TIMEOUT=18s
GATEWAY_AUTH_CIRCUIT_TIMEOUT=18s
GATEWAY_FILE_CIRCUIT_TIMEOUT=35s
GATEWAY_BULKHEAD_MAX_CONCURRENT_CALLS=50
GATEWAY_AUTH_BULKHEAD_MAX_CONCURRENT_CALLS=20
GATEWAY_FILE_BULKHEAD_MAX_CONCURRENT_CALLS=20

# Host ports for aggregate Compose infrastructure.
API_GATEWAY_EXPOSED_PORT=8080
EUREKA_EXPOSED_PORT=8761
CONFIG_SERVER_EXPOSED_PORT=8888

# Member Service database. Username and password have no application defaults.
MEMBER_DB_HOST=localhost
MEMBER_DB_PORT=5432
MEMBER_DB_NAME=digilib_member
MEMBER_DB_USERNAME=replace-with-the-member-database-user
MEMBER_DB_PASSWORD=replace-with-the-member-database-password
MEMBER_DB_EXPOSED_PORT=5437
MEMBER_SERVICE_EXPOSED_PORT=8082

# Catalog Service database and standalone debug port.
CATALOG_DB_NAME=catalog_service_dbs
CATALOG_DB_USERNAME=replace-with-the-catalog-database-user
CATALOG_DB_PASSWORD=replace-with-the-catalog-database-password
CATALOG_DB_EXPOSED_PORT=5438
CATALOG_SERVICE_EXPOSED_PORT=8081

# Loan Service database and standalone debug port.
LOAN_DB_NAME=loan_service_dbs
LOAN_DB_USERNAME=replace-with-the-loan-database-user
LOAN_DB_PASSWORD=replace-with-the-loan-database-password
LOAN_DB_EXPOSED_PORT=5439
LOAN_SERVICE_EXPOSED_PORT=8083

# Fine Service database and standalone debug port.
FINE_DB_NAME=fine_service
FINE_DB_USERNAME=replace-with-the-fine-database-user
FINE_DB_PASSWORD=replace-with-the-fine-database-password
FINE_DB_EXPOSED_PORT=5440
FINE_SERVICE_EXPOSED_PORT=8084

# Optional SePay integration. Empty values allow startup, but payment endpoints
# require real values before they can create QR codes or verify webhooks.
SEPAY_BANK=
SEPAY_ACCOUNT_NUMBER=
SEPAY_ACCOUNT_NAME=
SEPAY_SECRET_KEY=

# Notification Service database, SMTP, and standalone debug port.
NOTIFICATION_DB_NAME=notification_service_db
NOTIFICATION_DB_USERNAME=replace-with-the-notification-database-user
NOTIFICATION_DB_PASSWORD=replace-with-the-notification-database-password
NOTIFICATION_DB_EXPOSED_PORT=5441
NOTIFICATION_SERVICE_EXPOSED_PORT=8085
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Secure defaults for services started as local Java processes.
# In containers use 0.0.0.0, advertise the container DNS name through Eureka,
# and do not publish the business-service ports to the host.
INTERNAL_SERVICE_BIND_ADDRESS=127.0.0.1
INTERNAL_SERVICE_HOST=localhost
INFRA_BIND_ADDRESS=127.0.0.1
