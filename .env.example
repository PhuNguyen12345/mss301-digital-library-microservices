# Copy this file to .env. Never commit the resulting .env file.

# Local Keycloak infrastructure
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-a-long-random-admin-password

# The values below must describe the same Keycloak deployment and realm.
# Do not add a trailing slash to KEYCLOAK_BASE_URL.
KEYCLOAK_BASE_URL=http://localhost:8180
KEYCLOAK_REALM=digilib-realm
KEYCLOAK_ISSUER_URI=http://localhost:8180/realms/digilib-realm
KEYCLOAK_CLIENT_ID=digilib-auth
KEYCLOAK_CLIENT_SECRET=replace-with-the-newly-regenerated-client-secret
INTERNAL_API_KEY=replace-with-a-separate-long-random-service-key

# Comma-separated browser origins allowed to call API Gateway.
GATEWAY_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# API Gateway resilience guardrails. Duration values use Spring's format.
GATEWAY_CONNECT_TIMEOUT_MS=1000
GATEWAY_RESPONSE_TIMEOUT=5s
GATEWAY_AUTH_RESPONSE_TIMEOUT_MS=15000
GATEWAY_FILE_RESPONSE_TIMEOUT_MS=30000
GATEWAY_CIRCUIT_TIMEOUT=18s
GATEWAY_AUTH_CIRCUIT_TIMEOUT=18s
GATEWAY_FILE_CIRCUIT_TIMEOUT=35s
GATEWAY_BULKHEAD_MAX_CONCURRENT_CALLS=50
GATEWAY_AUTH_BULKHEAD_MAX_CONCURRENT_CALLS=20
GATEWAY_FILE_BULKHEAD_MAX_CONCURRENT_CALLS=20

# Member Service database. Username and password have no application defaults.
MEMBER_DB_HOST=localhost
MEMBER_DB_PORT=5432
MEMBER_DB_NAME=digilib_member
MEMBER_DB_USERNAME=replace-with-the-member-database-user
MEMBER_DB_PASSWORD=replace-with-the-member-database-password

# Secure defaults for services started as local Java processes.
# In containers use 0.0.0.0, advertise the container DNS name through Eureka,
# and do not publish the business-service ports to the host.
INTERNAL_SERVICE_BIND_ADDRESS=127.0.0.1
INTERNAL_SERVICE_HOST=localhost
INFRA_BIND_ADDRESS=127.0.0.1
